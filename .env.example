# Environment variables for Self-Healing CI/CD Pipeline
# Copy this file to .env and fill in your values

# GitHub Personal Access Token (required)
# Needs 'repo' scope for code access and push
GITHUB_PAT=your-github-token-here

# AWS Configuration
AWS_REGION=ap-northeast-1

# Terraform variables
TF_VAR_github_token=${GITHUB_PAT}
TF_VAR_github_repository=https://github.com/your-org/your-repo.git
TF_VAR_ai_agent_endpoint=https://your-ai-agent.com/ci_result

# Optional: AI Agent API Key (if your API requires authentication)
# TF_VAR_ai_agent_api_key=your-api-key